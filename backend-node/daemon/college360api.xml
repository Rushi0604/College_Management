<service>
	<id>college360api.exe</id>
	<name>College360 API</name>
	<description>MongoDB-backed data API for College360 (replaces Supabase). Serves http://localhost:4000</description>
	<executable>C:\Program Files\nodejs\node.exe</executable>
	<argument>--harmony</argument>
	<argument>D:\College_Management\backend-node\node_modules\node-windows\lib\wrapper.js</argument>
	<argument>--file</argument>
	<argument>D:\College_Management\backend-node\server.js</argument>
	<argument>--scriptoptions=</argument>
	<argument>--log</argument>
	<argument>College360 API wrapper</argument>
	<argument>--grow</argument>
	<argument>0.5</argument>
	<argument>--wait</argument>
	<argument>2</argument>
	<argument>--maxrestarts</argument>
	<argument>10</argument>
	<argument>--abortonerror</argument>
	<argument>n</argument>
	<argument>--stopparentfirst</argument>
	<argument>undefined</argument>
	<logmode>rotate</logmode>
	<stoptimeout>30sec</stoptimeout>
	<serviceaccount>
		<domain>SWARA-PC</domain>
		<user>LocalSystem</user>
		<password></password>
	</serviceaccount>
	<workingdirectory>D:\College_Management\backend-node</workingdirectory>
</service>