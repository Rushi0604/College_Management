# Copy this file to ".env" and adjust if needed. Defaults work for local MongoDB.
# Local MongoDB (default):
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=college360
PORT=4000

# To use a cloud database instead (MongoDB Atlas), set MONGO_URL to your
# Atlas connection string, e.g.:
# MONGO_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
