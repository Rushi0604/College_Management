{
  "name": "college-realtime",
  "version": "1.0.0",
  "description": "Real-time service for College Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "pm2:start": "npx pm2 start ecosystem.config.js",
    "pm2:stop": "npx pm2 stop ecosystem.config.js",
    "pm2:restart": "npx pm2 restart ecosystem.config.js",
    "pm2:status": "npx pm2 status",
    "pm2:logs": "npx pm2 logs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "pm2": "^7.0.3"
  }
}
